# Copy to .env.local and fill in. EXPO_PUBLIC_* vars are inlined into the JS
# bundle at build time — anyone with the app can extract them. Dev/demo only;
# without a key here the app shows a first-launch key screen instead (stored
# on-device via SecureStore).
EXPO_PUBLIC_CEREBRAS_API_KEY=csk-REPLACE_ME
# Optional: enables the web_search tool (Exa)
# EXPO_PUBLIC_EXA_API_KEY=
# Optional: real semantic photos instead of LoremFlickr
# EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=
# Optional overrides (any OpenAI-compatible endpoint works):
# EXPO_PUBLIC_CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# EXPO_PUBLIC_GENOS_MODEL=gemma-4-31b
